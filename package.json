{
  "name": "robotrock",
  "version": "0.9.0",
  "description": "Human-in-the-loop approval workflows for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./trigger": {
      "types": "./dist/trigger/index.d.ts",
      "import": "./dist/trigger/index.js"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.js"
    },
    "./ai/trigger": {
      "types": "./dist/ai/trigger.d.ts",
      "import": "./dist/ai/trigger.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js"
    },
    "./ai/workflow": {
      "types": "./dist/ai/workflow.d.ts",
      "import": "./dist/ai/workflow.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "robotrock",
    "human-in-the-loop",
    "approval",
    "workflow",
    "trigger.dev",
    "vercel-ai-sdk",
    "ai-sdk"
  ],
  "license": "MIT",
  "homepage": "https://docs.robotrock.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quintenb/robotrock-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/quintenb/robotrock-sdk/issues"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@trigger.dev/sdk": "4.4.6",
    "@types/node": "^26.0.1",
    "ai": "^7.0.4",
    "eslint": "^10.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "workflow": "^4.5.0"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@trigger.dev/sdk": "^3.0.0 || ^4.0.0",
    "ai": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "workflow": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "@trigger.dev/sdk": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "workflow": {
      "optional": true
    }
  }
}
